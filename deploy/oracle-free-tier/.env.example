# Oracle Cloud Always Free (ARM Ampere A1) 部署环境变量
# 复制为 .env 后填值；勿提交 .env 到仓库（.gitignore 已覆盖 .env）。
# chmod 600 .env 锁权限。

# ────────────────────────────────────────────
# 部署目标
# ────────────────────────────────────────────

# 根域名；Caddyfile 会拼成 app.${DOMAIN} 和 api.${DOMAIN}
DOMAIN=example.com

# GHCR 镜像 tag；务必锁版本，不要用 latest
# 看最新版本：https://github.com/xgyyx/contritas/releases
APP_VERSION=0.7.1

# ────────────────────────────────────────────
# 强随机密钥（务必重新生成；示例值已经全网公开）
# ────────────────────────────────────────────

# openssl rand -hex 24
POSTGRES_PASSWORD=

# openssl rand -hex 32
# 必须与构建 web 镜像时烤入的 NEXT_PUBLIC_API_TOKEN 完全一致
# （即 GitHub repo Secrets 里的 RELEASE_NEXT_PUBLIC_API_TOKEN）
API_AUTH_TOKEN=

# ────────────────────────────────────────────
# LLM Provider
# ────────────────────────────────────────────

LLM_PROVIDER=claude

# 当 LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
# 自定义 Anthropic endpoint（非 *.anthropic.com 会触发 warn 日志）
ANTHROPIC_BASE_URL=

# 当 LLM_PROVIDER=openai-compatible
# OPENAI_COMPATIBLE_API_KEY=
# OPENAI_COMPATIBLE_BASE_URL=
# OPENAI_COMPATIBLE_MODEL=

# 省钱关键：retrieval / inputValidation 走 cheap 模型
LLM_MODEL_CHEAP=claude-haiku-3-5-20241022

# ────────────────────────────────────────────
# 搜索 / 内容提取
# ────────────────────────────────────────────

TAVILY_API_KEY=
# SERPER_API_KEY=
# JINA_API_KEY=         # 留空走免费 tier
# FIRECRAWL_API_KEY=

# ────────────────────────────────────────────
# 限流（可选；不填走默认）
# ────────────────────────────────────────────

# RATE_LIMIT_IP_PER_MIN=60
# RATE_LIMIT_CREATE_PER_HOUR=10
