{
  "name": "@contritas/api",
  "version": "0.7.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "worker": "tsx src/worker.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@contritas/llm": "workspace:*",
    "@contritas/search": "workspace:*",
    "@contritas/shared": "workspace:*",
    "@contritas/workflow": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "bullmq": "^5.30.0",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "ioredis": "^5.4.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.0",
    "ulid": "^2.3.0",
    "xstate": "^5.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/ioredis-mock": "^8.2.7",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.28.0",
    "ioredis-mock": "^8.13.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
