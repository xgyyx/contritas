{
  "name": "@contritas/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "worker": "tsx src/worker.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "@hono/node-server": "^1.13.0",
    "bullmq": "^5.30.0",
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.0",
    "ioredis": "^5.4.0",
    "zod": "^3.23.0",
    "ulid": "^2.3.0",
    "xstate": "^5.18.0",
    "@contritas/shared": "workspace:*",
    "@contritas/workflow": "workspace:*",
    "@contritas/llm": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "drizzle-kit": "^0.28.0",
    "vitest": "^2.1.0"
  }
}
