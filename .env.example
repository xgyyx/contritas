# Database
DATABASE_URL=postgresql://postgres:dev@localhost:5432/contritas

# Redis
REDIS_URL=redis://localhost:6379

# LLM Provider 选择: claude | openai-compatible
LLM_PROVIDER=claude

# Anthropic (LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_BASE_URL=                   # 可选，留空则使用官方 API；非 *.anthropic.com 域名会触发启动警告

# OpenAI Compatible (LLM_PROVIDER=openai-compatible)
# OPENAI_COMPATIBLE_API_KEY=sk-xxx
# OPENAI_COMPATIBLE_BASE_URL=https://your-proxy.com/v1
# OPENAI_COMPATIBLE_MODEL=gpt-4o

# Search Providers
TAVILY_API_KEY=tvly-xxx               # 至少需要一个搜索 provider
# SERPER_API_KEY=xxx                  # 可选，备用搜索 provider

# Content Extractors
# JINA_API_KEY=jina_xxx               # 可选，Jina Reader 免费 tier 无需 key
# FIRECRAWL_API_KEY=fc-xxx            # 可选，备用内容提取器

# Server
PORT=4000

# ────────────────────────────────────────────
# Security (Phase 6.1)
# ────────────────────────────────────────────

# CORS allowlist — 逗号分隔多个 origin。生产环境必填。
WEB_ORIGIN=http://localhost:3000

# API 鉴权 Bearer token — 逗号分隔可填多个（轮换 / 多客户端）。必填。
# 生成示例：openssl rand -hex 32
API_AUTH_TOKEN=dev-token-change-me

# 限流（可选；缺失则使用默认值）
# RATE_LIMIT_IP_PER_MIN=60
# RATE_LIMIT_CREATE_PER_HOUR=10

# 前端（apps/web）— 必须与 API_AUTH_TOKEN 中的一个值一致
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_API_TOKEN=dev-token-change-me
