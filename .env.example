# Database
DATABASE_URL=postgresql://postgres:dev@localhost:5432/contritas

# Redis
REDIS_URL=redis://localhost:6379

# LLM Provider 选择: claude | openai-compatible
LLM_PROVIDER=claude

# Anthropic (LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_BASE_URL=                   # 可选，留空则使用官方 API

# OpenAI Compatible (LLM_PROVIDER=openai-compatible)
# OPENAI_COMPATIBLE_API_KEY=sk-xxx
# OPENAI_COMPATIBLE_BASE_URL=https://your-proxy.com/v1
# OPENAI_COMPATIBLE_MODEL=gpt-4o

# Server
PORT=4000
